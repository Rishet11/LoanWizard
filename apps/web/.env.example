# Postgres (Neon or Railway)
DATABASE_URL=postgresql://user:password@host/dbname

# ML service (Stream B)
ML_SERVICE_URL=http://localhost:8000

# Set to "real" after Stream B integration
NEXT_PUBLIC_ML_MODE=mock

# Set to "false" after Stream A integration
USE_MOCK_PERCEPTION=true

# Admin password (demo-grade shared secret)
ADMIN_PASSWORD=admin123
