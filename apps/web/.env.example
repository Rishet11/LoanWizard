# Postgres (Neon recommended for hosted demo)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ML service (Stream B)
ML_SERVICE_URL=http://localhost:8000

# Public demo offer mode. Keep "mock" for the reliable judge link; use "real"
# locally or in admin testing to call the live ML service.
NEXT_PUBLIC_ML_MODE=mock

# Public demo perception mode. Keep "true" on the hosted judge link.
NEXT_PUBLIC_USE_MOCK_PERCEPTION=true

# Required in production. Use a strong unique secret in HF/Vercel settings.
ADMIN_PASSWORD=replace-with-strong-secret
